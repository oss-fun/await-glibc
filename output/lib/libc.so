GROUP ( //home/mouse/await-glibc/output/lib/libc.so.6 //home/mouse/await-glibc/output/lib/libc_nonshared.a  AS_NEEDED ( //home/mouse/await-glibc/output/lib/ld-linux-x86-64.so.2 ) )
